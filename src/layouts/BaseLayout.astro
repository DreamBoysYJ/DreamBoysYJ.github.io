---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Youngju Notes",
  description = "Velog에서 시작해 GitHub에 원본을 남기는 개발 블로그.",
  image = "https://images.unsplash.com/photo-1499750310107-5fef28a66643?auto=format&fit=crop&w=1800&q=80"
} = Astro.props;

const pageTitle = title === "Youngju Notes" ? title : `${title} | Youngju Notes`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Youngju Notes RSS" href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <span class="brand-mark" aria-hidden="true"></span>
        <span>Youngju Notes</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/">글</a>
        <a href="/tags/">태그</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>GitHub Markdown을 원본으로 삼고, 발행은 확인 후 천천히.</p>
    </footer>
  </body>
</html>
